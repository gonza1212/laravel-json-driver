{
    "name": "gonza1212/laravel-json-driver",
    "description": "Driver de base de datos JSON para Laravel 13 — persistencia local sin base de datos externa",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^11.0",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Gonza1212\\JsonDriver\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gonza1212\\JsonDriver\\Tests\\": "tests/",
            "Database\\Factories\\": "tests/Factories/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Gonza1212\\JsonDriver\\JsonServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "analyse": "php -d memory_limit=512M vendor/bin/phpstan analyse --level=5"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
